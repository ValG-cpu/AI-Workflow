      "name": "01 - Extract WF01 Payload"
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\n\nconst qualityGate = input.quality_gate || {};\nconst requirementAnalysis = input.requirement_analysis || {};\n\nconst passed =\n  qualityGate.passed === true &&\n  requirementAnalysis.is_ready_for_design === true;\n\nif (!passed) {\n  return [\n    {\n      json: {\n        ...input,\n        wf02_validation: {\n          passed: false,\n          reason: \"WF01 quality gate did not pass\"\n        },\n        current_workflow: \"WF02\",\n        next_workflow: \"WF08\",\n        status: \"BLOCKED\"\n      }\n    }\n  ];\n}\n\nreturn [\n  {\n    json: {\n      ...input,\n      wf02_validation: {\n        passed: true\n      }\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        416,
        0
      ],
      "id": "b6d048cb-bc07-46c7-b4db-21fb7cd9c5ce",
      "name": "02 - Validate WF01 Approval"
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 3
          },
          "conditions": [
            {
              "id": "1280cf6c-362c-43a2-a285-5a0ab1464f8e",
              "leftValue": "={{ $json.wf02_validation.passed }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
