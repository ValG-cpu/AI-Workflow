      "id": "a73d54ac-9466-4d5f-b319-b428322551ca",
      "name": "05 - Parse AI Architecture"
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\n\nconst original =\n  $('01 - Extract WF01 Payload').item.json;\n\nconst payload = original.payload;\n\nconst result = input.wf02_result;\n\nconst nextWorkflow =\n  result.quality_gate?.passed === true\n    ? \"WF03\"\n    : \"WF08\";\n\nconst updatedPayload = {\n  ...payload,\n\n  factory: {\n    ...payload.factory,\n    current_workflow: \"WF02\",\n    next_workflow: nextWorkflow,\n    status:\n      nextWorkflow === \"WF03\"\n        ? \"RUNNING\"\n        : \"BLOCKED\",\n\n    workflow_history: [\n      ...(payload.factory.workflow_history || []),\n      \"WF02\"\n    ]\n  },\n\n  technical_design: result.technical_design,\n\n  quality_gate: result.quality_gate,\n\n  artifacts: [\n    ...(payload.artifacts || []),\n\n    {\n      workflow: \"WF02\",\n      type: \"technical_design\",\n      name: \"technical_design.json\",\n      content: result.technical_design\n    }\n  ]\n};\n\nreturn [\n  {\n    json: {\n      execution_id: original.execution_id,\n      payload: updatedPayload,\n      current_workflow: \"WF02\",\n      next_workflow: nextWorkflow,\n      status: updatedPayload.factory.status,\n      quality_gate: result.quality_gate\n    }\n  }\n];"
      },
