      "id": "843e21a9-fd14-472c-85d9-52a67a523f68",
      "name": "04B - Prepare WF08 Escalation"
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\n\nlet raw =\n  input.output ||\n  input.text ||\n  input.response ||\n  input.content ||\n  input.message ||\n  input.data;\n\nif (!raw && input.messages?.length) {\n  raw = input.messages[0]?.content;\n}\n\nif (!raw) {\n  return [\n    {\n      json: {\n        ...input,\n        wf02_result: {\n          technical_design: {\n  architecture_summary: \"INVALID\",\n  project_structure: [\"UNDEFINED\"],\n  components: [\"UNDEFINED\"],\n  api_endpoints: [\"UNDEFINED\"],\n  services: [\"UNDEFINED\"],\n  database_requirements: [\"UNDEFINED\"],\n  docker_requirements: [\"UNDEFINED\"],\n  ci_cd_requirements: [\"UNDEFINED\"],\n  testing_strategy: [\"UNDEFINED\"],\n  dependencies: [\"UNDEFINED\"],\n  technical_risks: [\"UNDEFINED\"],\n  implementation_notes: [\"UNDEFINED\"]\n},\n          quality_gate: {\n            passed: false,\n            blocking_issues: [\"No AI output found\"],\n            recommendation: \"HUMAN_REVIEW\"\n          },\n          next_workflow: \"WF08\"\n        }\n      }\n    }\n  ];\n}\n\nif (typeof raw !== \"string\") {\n  raw = JSON.stringify(raw);\n}\n\nraw = raw\n  .replace(/```json/g, \"\")\n  .replace(/```/g, \"\")\n  .replace(/\\/\\/.*$/gm, \"\")\n  .trim();\n\nconst firstBrace = raw.indexOf(\"{\");\nconst lastBrace = raw.lastIndexOf(\"}\");\n\nif (firstBrace === -1 || lastBrace === -1) {\n  return [\n    {\n      json: {\n        ...input,\n        wf02_result: {\n          technical_design: {\n  architecture_summary: \"INVALID\",\n  project_structure: [\"UNDEFINED\"],\n  components: [\"UNDEFINED\"],\n  api_endpoints: [\"UNDEFINED\"],\n  services: [\"UNDEFINED\"],\n  database_requirements: [\"UNDEFINED\"],\n  docker_requirements: [\"UNDEFINED\"],\n  ci_cd_requirements: [\"UNDEFINED\"],\n  testing_strategy: [\"UNDEFINED\"],\n  dependencies: [\"UNDEFINED\"],\n  technical_risks: [\"UNDEFINED\"],\n  implementation_notes: [\"UNDEFINED\"]\n},\n          quality_gate: {\n            passed: false,\n            blocking_issues: [\"Invalid AI JSON\"],\n            recommendation: \"HUMAN_REVIEW\"\n          },\n          next_workflow: \"WF08\"\n        }\n      }\n    }\n  ];\n}\n\nconst jsonString =\n  raw.slice(firstBrace, lastBrace + 1);\n\nlet parsed;\n\ntry {\n  parsed = JSON.parse(jsonString);\n}\ncatch (error) {\n  return [\n    {\n      json: {\n        ...input,\n        wf02_result: {\n          technical_design: {\n  architecture_summary: \"INVALID\",\n  project_structure: [\"UNDEFINED\"],\n  components: [\"UNDEFINED\"],\n  api_endpoints: [\"UNDEFINED\"],\n  services: [\"UNDEFINED\"],\n  database_requirements: [\"UNDEFINED\"],\n  docker_requirements: [\"UNDEFINED\"],\n  ci_cd_requirements: [\"UNDEFINED\"],\n  testing_strategy: [\"UNDEFINED\"],\n  dependencies: [\"UNDEFINED\"],\n  technical_risks: [\"UNDEFINED\"],\n  implementation_notes: [\"UNDEFINED\"]\n},\n          quality_gate: {\n            passed: false,\n            blocking_issues: [error.message],\n            recommendation: \"HUMAN_REVIEW\"\n          },\n          next_workflow: \"WF08\"\n        }\n      }\n    }\n  ];\n}\n\nreturn [\n  {\n    json: {\n      ...input,\n      wf02_result: parsed\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1184,
