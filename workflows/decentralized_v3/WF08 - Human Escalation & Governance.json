    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\n\nconst payload =\n  input.payload || {};\n\nconst updatedPayload = {\n\n  ...payload,\n\n  governance: {\n\n    escalation_workflow:\n      input.current_workflow,\n\n    escalation_status:\n      \"ESCALATED\",\n\n    root_cause_analysis:\n      input.root_cause_analysis,\n\n    human_action_plan:\n      input.human_action_plan,\n\n    retry_strategy:\n      input.retry_strategy\n  }\n};\n\nreturn [\n  {\n    json: {\n\n      execution_id:\n        input.execution_id,\n\n      payload:\n        updatedPayload,\n\n      current_workflow:\n        \"WF08\",\n\n      next_workflow:\n        null,\n\n      status:\n        \"ESCALATED\"\n    }\n  }\n];"
