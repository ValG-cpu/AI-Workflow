      "id": "48781dba-67f6-4b6a-a9b3-6ccbb46ebe88",
      "name": "01 - Extract Escalation Payload"
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\n\nconst missing = [];\n\nif (!input.execution_id) {\n  missing.push(\"execution_id\");\n}\n\nif (!input.current_workflow) {\n  missing.push(\"current_workflow\");\n}\n\nif (!input.status) {\n  missing.push(\"status\");\n}\n\nif (!input.quality_gate) {\n  missing.push(\"quality_gate\");\n}\n\nreturn [\n  {\n    json: {\n      ...input,\n\n      escalation_validation: {\n        passed: missing.length === 0,\n        missing_fields: missing\n      }\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        416,
        0
      ],
      "id": "ad2f288a-e68e-4040-b088-e12824f14d9e",
      "name": "02 - Validate Escalation Context"
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 3
          },
          "conditions": [
            {
              "id": "ffeedd79-1737-4af0-94aa-50a8370a63f7",
              "leftValue": "={{ $json.escalation_validation.passed }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [
        624,
        0
      ],
      "id": "fc6f8c9a-793a-46f2-998a-708963494279",
      "name": "03 - IF Escalation Valid?"
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\n\nconst summary = {\n\n  execution_id:\n    input.execution_id,\n\n  failed_workflow:\n    input.current_workflow,\n\n  workflow_target:\n    input.next_workflow,\n\n  status:\n    input.status,\n\n  blocking_issues:\n    input.quality_gate.blocking_issues || [],\n\n  recommendation:\n    input.quality_gate.recommendation || \"UNKNOWN\"\n};\n\nreturn [\n  {\n    json: {\n      ...input,\n      escalation_summary: summary\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        832,
        -96
      ],
      "id": "4b14e49e-098c-46f6-8ae3-e580d92a9711",
      "name": "04 - Generate Failure Summary"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Analyze this software factory execution failure.\n\nFailure Summary:\n{{ JSON.stringify($json.escalation_summary) }}\n\nReturn:\n\n{\n  \"root_cause_analysis\": {\n    \"failure_type\": \"\",\n    \"severity\": \"\",\n    \"probable_root_cause\": \"\",\n    \"recommended_fix\": \"\",\n    \"retry_recommended\": true\n  }\n}\n\n\nReturn ONLY valid JSON.\nNo markdown.\nNo explanations.\nNo comments.\nOutput must be parseable by JSON.parse().",
        "options": {
          "systemMessage": "You are an industrial software governance auditor.\n\nYour role is to analyze software factory failures.\n\nYou must:\n- identify probable root causes\n- estimate severity\n- classify the failure type\n- propose remediation guidance\n\nReturn ONLY valid JSON."
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        1040,
        -96
      ],
      "id": "72b46ccf-c13e-44a6-8906-386e170c86f5",
      "name": "05 - AI Root Cause Analysis"
    },
    {
      "parameters": {
        "model": "hermes3:8b",
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.lmChatOllama",
      "typeVersion": 1,
      "position": [
        1040,
        32
      ],
      "id": "25479cc6-2e29-413e-b486-e598721a6ea4",
      "name": "Ollama Chat Model (Hermes)",
      "credentials": {
        "ollamaApi": {
          "id": "p0mzco8CfGCSmy9I",
          "name": "Ollama account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\n\nlet raw =\n  input.output ||\n  input.text ||\n  input.response ||\n  input.content;\n\nif (!raw) {\n  throw new Error(\n    \"No root cause analysis output found\"\n  );\n}\n\nif (typeof raw !== \"string\") {\n  raw = JSON.stringify(raw);\n}\n\nraw = raw.trim();\n\nconst firstBrace =\n  raw.indexOf(\"{\");\n\nconst lastBrace =\n  raw.lastIndexOf(\"}\");\n\nif (\n  firstBrace === -1 ||\n  lastBrace === -1\n) {\n  throw new Error(\n    \"No valid JSON found\"\n  );\n}\n\nconst parsed =\n  JSON.parse(\n    raw.slice(firstBrace, lastBrace + 1)\n  );\n\nconst analysis =\n  parsed.root_cause_analysis;\n\nconst plan = {\n\n  failed_workflow:\n    input.current_workflow,\n\n  severity:\n    analysis.severity,\n\n  probable_root_cause:\n    analysis.probable_root_cause,\n\n  recommended_fix:\n    analysis.recommended_fix,\n\n  retry_recommended:\n    analysis.retry_recommended\n};\n\nreturn [\n  {\n    json: {\n      ...input,\n      root_cause_analysis: analysis,\n      human_action_plan: plan\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1392,
        -96
      ],
      "id": "11f23eea-70f6-4979-89e9-943d10880c5a",
      "name": "06 - Generate Human Action Plan"
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\n\nconst retry =\n  input.root_cause_analysis\n    .retry_recommended;\n\nconst retryStrategy = {\n\n  retry_allowed:\n    retry,\n\n  retry_workflow:\n    retry\n      ? input.current_workflow\n      : null,\n\n  retry_mode:\n    retry\n      ? \"HUMAN_APPROVED_RETRY\"\n      : \"NO_RETRY\"\n};\n\nreturn [\n  {\n    json: {\n      ...input,\n      retry_strategy: retryStrategy\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1600,
        -96
      ],
      "id": "79f3e26e-789e-4d06-893a-a71126aa2b9f",
