        "jsCode": "const runs =\n  $('07 - Get Pipeline Status').item.json.workflow_runs || [];\n\nconst latestRun = runs[0];\n\nif (!latestRun) {\n  return [{\n    json: {\n      pipeline_analysis: {\n        success: false,\n        pending: false,\n        failed: true,\n        pipeline_state: \"NOT_FOUND\",\n        pipeline_result: \"NO_RUN\"\n      }\n    }\n  }];\n}\n\nconst isCompleted =\n  latestRun.status === \"completed\";\n\nconst isSuccess =\n  latestRun.conclusion === \"success\";\n\nconst isPending =\n  !isCompleted;\n\nconst isFailed =\n  isCompleted && latestRun.conclusion !== \"success\";\n\nreturn [{\n  json: {\n    pipeline_analysis: {\n      success: isSuccess,\n      pending: isPending,\n      failed: isFailed,\n      pipeline_state: latestRun.status,\n      pipeline_result: latestRun.conclusion,\n      pipeline_run_id: latestRun.id,\n      github_run_url: latestRun.html_url\n    }\n  }\n}];"
