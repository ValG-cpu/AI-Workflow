    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\n\nconst previous =\n  $('05 - Extract Pipeline Run Info')\n    .item.json;\n\nconst payload =\n  previous.payload;\n\nconst updatedPayload = {\n\n  ...payload,\n\n  factory: {\n    ...payload.factory,\n\n    current_workflow: \"WF06\",\n    next_workflow: \"WF07\",\n    status: \"RUNNING\",\n\n    workflow_history: [\n      ...(payload.factory.workflow_history || []),\n      \"WF06\"\n    ]\n  },\n\n  ci_cd_execution: {\n\n    pipeline_run_id:\n  $('07C - Analyze GitHub Workflow Result')\n    .item.json.pipeline_analysis.pipeline_run_id,\n\n    pipeline_result:\n  $('07C - Analyze GitHub Workflow Result')\n    .item.json.pipeline_analysis.pipeline_result,\n\n    github_run_url:\n  $('07C - Analyze GitHub Workflow Result')\n    .item.json.pipeline_analysis.github_run_url,\n\n    pipeline_analysis:\n      $('07C - Analyze GitHub Workflow Result')\n      .item.json.pipeline_analysis\n  }\n};\n\nreturn [\n  {\n    json: {\n\n      execution_id:\n        previous.execution_id,\n\n      payload:\n        updatedPayload,\n\n      current_workflow:\n        \"WF06\",\n\n      next_workflow:\n        \"WF07\",\n\n      status:\n        \"RUNNING\"\n    }\n  }\n];"
      },
