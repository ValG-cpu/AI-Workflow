      "parameters": {
        "jsCode": "const input = $input.first().json;\n\nconst workItemId = input.work_item_id;\n\nconst executionId =\n  input.execution_id\n    .replace(/[^a-zA-Z0-9-]/g, \"-\")\n    .slice(0, 20);\n\nconst branchName =\n  `feature/wf05-us-${workItemId}-${executionId}`;\n\nreturn [\n  {\n    json: {\n      ...input,\n      branch_name: branchName\n    }\n  }\n];"
