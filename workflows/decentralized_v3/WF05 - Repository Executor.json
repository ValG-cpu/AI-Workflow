    {
      "parameters": {
        "jsCode": "const fs = require(\"fs\");\nconst path = require(\"path\");\n\nconst context =\n  $('05 - Prepare Workspace Paths').item.json;\n\nconst repoPath = context.repo_path;\nconst files = context.generated_files;\n\nfor (const file of files) {\n\n  let relativePath =\n    (file.path || \"\")\n      .replace(/\\\\/g, \"/\")\n      .replace(/^\\/+/, \"\")\n      .replace(/^.*ai_factory_workspace\\/[^/]+\\//, \"\");\n\n  const fullPath =\n  path.join(repoPath, \"product-app\", relativePath);\n\n  const dir =\n    path.dirname(fullPath);\n\n  fs.mkdirSync(dir, {\n    recursive: true\n  });\n\n  fs.writeFileSync(\n    fullPath,\n    file.content,\n    \"utf8\"\n  );\n}\n\nreturn [\n  {\n    json: context\n  }\n];"
      },
