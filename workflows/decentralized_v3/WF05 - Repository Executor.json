      "parameters": {
        "jsCode": "const input =\n  $('05 - Prepare Workspace Paths').item.json;\n\nconst original =\n  $('01 - Extract WF04 Payload').item.json;\n\nconst payload =\n  original.payload;\n\nconst updatedPayload = {\n  ...payload,\n\n  factory: {\n    ...payload.factory,\n    current_workflow: \"WF05\",\n    next_workflow: \"WF06\",\n    status: \"RUNNING\",\n\n    workflow_history: [\n      ...(payload.factory.workflow_history || []),\n      \"WF05\"\n    ]\n  },\n\n  repository_execution: {\n    repository_url: input.repo_url,\n    branch_name: input.branch_name,\n    commit_generated: true,\n    repository_path: input.repo_path\n  }\n};\n\nreturn [\n  {\n    json: {\n      execution_id: original.execution_id,\n      payload: updatedPayload,\n      current_workflow: \"WF05\",\n      next_workflow: \"WF06\",\n      status: \"RUNNING\",\n      quality_gate: {\n        passed: true,\n        blocking_issues: [],\n        recommendation: \"CONTINUE\"\n      }\n    }\n  }\n];"
