    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\n\nconst files = input.generated_files || [];\n\nif (!Array.isArray(files) || files.length === 0) {\n  return [\n    {\n      json: {\n        ...input,\n        wf05_validation: {\n          passed: false,\n          reason: \"No generated files found\"\n        },\n        current_workflow: \"WF05\",\n        next_workflow: \"WF08\",\n        status: \"BLOCKED\"\n      }\n    }\n  ];\n}\n\nconst invalidFiles = files.filter(file => {\n  return !file.path || typeof file.content !== \"string\";\n});\n\nif (invalidFiles.length > 0) {\n  return [\n    {\n      json: {\n        ...input,\n        wf05_validation: {\n          passed: false,\n          reason: \"Invalid generated files\"\n        },\n        current_workflow: \"WF05\",\n        next_workflow: \"WF08\",\n        status: \"BLOCKED\"\n      }\n    }\n  ];\n}\n\nreturn [\n  {\n    json: {\n      ...input,\n      wf05_validation: {\n        passed: true\n      }\n    }\n  }\n];"
      },
