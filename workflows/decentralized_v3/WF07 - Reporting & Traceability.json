      "id": "cd708d3c-3e46-4f15-9160-1aba9aab08ee",
      "name": "01 - Extract WF06 Payload"
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\n\nconst missing = [];\n\nif (!input.execution_id) {\n  missing.push(\"execution_id\");\n}\n\nif (!input.payload) {\n  missing.push(\"payload\");\n}\n\nif (!input.workflow_history) {\n  missing.push(\"workflow_history\");\n}\n\nif (!input.branch_name) {\n  missing.push(\"branch_name\");\n}\n\nif (!input.pipeline_run_id) {\n  missing.push(\"pipeline_run_id\");\n}\n\nif (missing.length > 0) {\n\n  return [\n    {\n      json: {\n        ...input,\n\n        reporting_validation: {\n          passed: false,\n          missing_fields: missing\n        },\n\n        current_workflow: \"WF07\",\n        next_workflow: \"WF08\",\n        status: \"BLOCKED\"\n      }\n    }\n  ];\n}\n\nreturn [\n  {\n    json: {\n      ...input,\n\n      reporting_validation: {\n        passed: true\n      }\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        416,
        0
      ],
      "id": "2cea385b-f83e-4879-ba43-29382672d43e",
