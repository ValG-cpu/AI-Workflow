      "id": "66458e66-4092-487b-9783-0a2d96e271aa",
      "name": "03B - Prepare WF08 Escalation"
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\n\nconst files =\n  input.generated_files || [];\n\nconst summary = {\n\n  execution_id:\n    input.execution_id,\n\n  work_item_id:\n    input.work_item_id,\n\n  title:\n    input.title,\n\n  workflow_count:\n    input.workflow_history.length,\n\n  workflows_executed:\n    input.workflow_history,\n\n  generated_files_count:\n    files.length,\n\n  branch_name:\n    input.branch_name,\n\n  pipeline_run_id:\n    input.pipeline_run_id,\n\n  pipeline_result:\n    input.pipeline_result,\n\n  execution_status:\n    \"SUCCESS\"\n};\n\nreturn [\n  {\n    json: {\n      ...input,\n      execution_summary: summary\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        832,
        -96
      ],
      "id": "7efda96b-7af6-4168-9aca-5631fa750adf",
      "name": "04 - Generate Execution Summary"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Generate an industrial execution report.\n\nExecution Summary:\n{{ JSON.stringify($json.execution_summary) }}\n\nPipeline Analysis:\n{{ JSON.stringify($json.payload.ci_cd_execution.pipeline_analysis) }}\n\nReturn this JSON:\n\n{\n  \"industrial_report\": {\n    \"executive_summary\": \"\",\n    \"delivery_summary\": \"\",\n    \"quality_assessment\": \"\",\n    \"traceability_assessment\": \"\",\n    \"industrialization_assessment\": \"\",\n    \"final_recommendation\": \"\"\n  }\n}\n\nReturn ONLY valid JSON.\nNo markdown.\nNo explanations.\nNo comments.\nOutput must be parseable by JSON.parse().",
        "options": {
          "systemMessage": "You are an industrial software delivery auditor.\n\nYour role is to generate a concise but professional execution report for an AI Software Factory.\n\nYou must summarize:\n- user story processed\n- workflows executed\n- generated assets\n- repository activity\n- CI/CD execution\n- traceability\n- quality governance\n- industrial maturity\n\nReturn ONLY valid JSON."
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        1040,
        -96
      ],
      "id": "1e24b67b-6fb7-4d3d-a119-ce7156045bb8",
      "name": "05 - Build Industrial Report"
    },
    {
      "parameters": {
        "model": "hermes3:8b",
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.lmChatOllama",
      "typeVersion": 1,
      "position": [
        1040,
        16
      ],
      "id": "2a61bdb1-1d99-49fe-93f0-87ef4bf6ea5f",
      "name": "Ollama Chat Model (Hermes)",
      "credentials": {
        "ollamaApi": {
          "id": "p0mzco8CfGCSmy9I",
          "name": "Ollama account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const aiOutput = $input.first().json;\n\nconst input =\n  $('04 - Generate Execution Summary').item.json;\n\nlet raw =\n  aiOutput.output ||\n  aiOutput.text ||\n  aiOutput.response ||\n  aiOutput.content;\n\nif (!raw) {\n  throw new Error(\"No AI report output found\");\n}\n\nif (typeof raw !== \"string\") {\n  raw = JSON.stringify(raw);\n}\n\nraw = raw.trim();\n\nconst firstBrace = raw.indexOf(\"{\");\nconst lastBrace = raw.lastIndexOf(\"}\");\n\nif (firstBrace === -1 || lastBrace === -1) {\n  throw new Error(\"No valid JSON found\");\n}\n\nconst jsonString =\n  raw.slice(firstBrace, lastBrace + 1);\n\nconst report =\n  JSON.parse(jsonString);\n\nconst traceability = {\n\n  work_item_id:\n    input.work_item_id,\n\n  title:\n    input.title,\n\n  workflows:\n    input.workflow_history,\n\n  repository_branch:\n    input.branch_name,\n\n  pipeline_run_id:\n    input.pipeline_run_id,\n\n  generated_files:\n    (input.generated_files || []).map(\n      file => file.path\n    )\n};\n\nreturn [\n  {\n    json: {\n      ...input,\n\n      industrial_report:\n        report.industrial_report,\n\n      traceability_matrix:\n        traceability\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1392,
        -96
      ],
      "id": "3e2f7817-c133-42e1-8b57-e7e099bef144",
      "name": "06 - Generate Traceability Matrix"
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\n\nconst payload =\n  input.payload;\n\nconst updatedPayload = {\n\n  ...payload,\n\n  factory: {\n    ...payload.factory,\n\n    current_workflow:\n      \"WF07\",\n\n    next_workflow:\n      null,\n\n    status:\n      \"COMPLETED\",\n\n    workflow_history: [\n      ...(payload.factory.workflow_history || []),\n      \"WF07\"\n    ]\n  },\n\n  industrial_report:\n    input.industrial_report,\n\n  traceability_matrix:\n    input.traceability_matrix\n};\n\nreturn [\n  {\n    json: {\n\n      execution_id:\n        input.execution_id,\n\n      payload:\n        updatedPayload,\n\n      current_workflow:\n        \"WF07\",\n\n      next_workflow:\n        null,\n\n      status:\n        \"COMPLETED\"\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
