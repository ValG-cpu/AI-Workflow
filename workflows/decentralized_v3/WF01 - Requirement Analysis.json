      ],
      "id": "563a4d7f-8985-4f3c-9919-2aff2ce13181",
      "name": "05 - Parse AI JSON Output"
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\n\nconst original =\n  $('01 - Extract Factory Payload').item.json;\n\nconst payload =\n  original.payload;\n\nconst result =\n  input.wf01_result;\n\nconst passed =\n  result.requirement_analysis?.is_ready_for_design !== false &&\n  result.quality_gate?.recommendation !== \"REJECT\";\n\nconst nextWorkflow =\n  passed ? \"WF02\" : \"WF08\";\n\nconst updatedPayload = {\n  ...payload,\n\n  factory: {\n    ...payload.factory,\n    current_workflow: \"WF01\",\n    next_workflow: nextWorkflow,\n    status: passed ? \"RUNNING\" : \"BLOCKED\",\n\n    workflow_history: [\n      ...(payload.factory.workflow_history || [\"WF00\"]),\n      \"WF01\"\n    ]\n  },\n\n  requirement_analysis:\n    result.requirement_analysis,\n\n  quality_gate:\n    result.quality_gate,\n\n  artifacts: [\n    ...(payload.artifacts || []),\n    {\n      workflow: \"WF01\",\n      type: \"requirement_analysis\",\n      name: \"requirement_analysis.json\",\n      content: result\n    }\n  ]\n};\n\nreturn [\n  {\n    json: {\n      execution_id: original.execution_id,\n      payload: updatedPayload,\n      current_workflow: \"WF01\",\n      next_workflow: nextWorkflow,\n      status: updatedPayload.factory.status,\n      quality_gate: result.quality_gate\n    }\n  }\n];"
      },
