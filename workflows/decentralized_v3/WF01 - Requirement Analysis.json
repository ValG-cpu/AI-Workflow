      "id": "dafcde25-a70f-4c1d-8073-323035095e8e",
      "name": "01 - Extract Factory Payload"
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\n\nconst missing = [];\n\nif (!input.execution_id) {\n  missing.push(\"execution_id\");\n}\n\nif (!input.payload) {\n  missing.push(\"payload\");\n}\n\nif (!input.title) {\n  missing.push(\"title\");\n}\n\nif (!input.description) {\n  missing.push(\"description\");\n}\n\nif (!input.acceptance_criteria) {\n  missing.push(\"acceptance_criteria\");\n}\n\nif (missing.length > 0) {\n  return [\n    {\n      json: {\n        ...input,\n        requirement_validation: {\n          passed: false,\n          missing_fields: missing\n        },\n        factory_decision: {\n          status: \"BLOCKED\",\n          next_workflow: \"WF08\",\n          reason: \"Missing required User Story fields\"\n        }\n      }\n    }\n  ];\n}\n\nreturn [\n  {\n    json: {\n      ...input,\n      requirement_validation: {\n        passed: true,\n        missing_fields: []\n      }\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        384,
        48
      ],
      "id": "951968a4-da4a-4721-90d8-d046fd7aeaa2",
      "name": "02 - Validate Required Fields"
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 3
          },
          "conditions": [
            {
              "id": "69e185ee-d01c-4f43-9d39-d0bdab8700e0",
              "leftValue": "={{ $json.requirement_validation.passed }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [
        592,
        48
      ],
      "id": "346242d3-00db-49c7-8081-ee64ca520e1b",
      "name": "03 — IF Required Fields Valid?"
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\n\nlet raw =\n  input.output ||\n  input.text ||\n  input.response ||\n  input.message ||\n  input.content ||\n  input.result ||\n  input.choices?.[0]?.message?.content;\n\nif (!raw) {\n  return [\n    {\n      json: {\n        ...input,\n        wf01_result: {\n          requirement_analysis: {\n            is_ready_for_design: false,\n            summary: \"No AI output found\",\n            ambiguities: [],\n            missing_information: [\"AI model returned no readable output\"],\n            risks: [],\n            normalized_user_story: \"\",\n            validated_acceptance_criteria: []\n          },\n          quality_gate: {\n            passed: false,\n            blocking_issues: [\"No AI output found\"],\n            recommendation: \"HUMAN_REVIEW\"\n          },\n          next_workflow: \"WF08\"\n        }\n      }\n    }\n  ];\n}\n\nif (typeof raw !== \"string\") {\n  raw = JSON.stringify(raw);\n}\n\nraw = raw\n  .replace(/```json/g, \"\")\n  .replace(/```/g, \"\")\n  .trim();\n\nconst firstBrace = raw.indexOf(\"{\");\nconst lastBrace = raw.lastIndexOf(\"}\");\n\nif (firstBrace === -1 || lastBrace === -1) {\n  return [\n    {\n      json: {\n        ...input,\n        wf01_result: {\n          requirement_analysis: {\n            is_ready_for_design: false,\n            summary: \"AI output did not contain valid JSON\",\n            ambiguities: [],\n            missing_information: [\"Invalid JSON structure\"],\n            risks: [],\n            normalized_user_story: \"\",\n            validated_acceptance_criteria: []\n          },\n          quality_gate: {\n            passed: false,\n            blocking_issues: [\"AI output did not contain valid JSON\"],\n            recommendation: \"HUMAN_REVIEW\"\n          },\n          next_workflow: \"WF08\"\n        }\n      }\n    }\n  ];\n}\n\nconst jsonString = raw.slice(firstBrace, lastBrace + 1);\n\nlet parsed;\n\ntry {\n  parsed = JSON.parse(jsonString);\n}\ncatch (error) {\n  return [\n    {\n      json: {\n        ...input,\n        wf01_result: {\n          requirement_analysis: {\n            is_ready_for_design: false,\n            summary: \"AI output JSON could not be parsed\",\n            ambiguities: [],\n            missing_information: [error.message],\n            risks: [],\n            normalized_user_story: \"\",\n            validated_acceptance_criteria: []\n          },\n          quality_gate: {\n            passed: false,\n            blocking_issues: [\"AI output JSON parse failed\"],\n            recommendation: \"HUMAN_REVIEW\"\n          },\n          next_workflow: \"WF08\"\n        }\n      }\n    }\n  ];\n}\n\nreturn [\n  {\n    json: {\n      ...input,\n      wf01_result: parsed\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1184,
